NODE_ENV=development
APP_URL=http://localhost:18080
PORT=3000
SESSION_SECRET=change-me-at-least-32-characters
TRUST_PROXY=false

DATABASE_URL=postgres://rpl:rpl@localhost:15432/rpl_gpu
DATABASE_POOL_MAX=5
DATABASE_CONNECTION_TIMEOUT_MS=3000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_MAX_LIFETIME_SECONDS=300
SESSION_DATABASE_POOL_MAX=2
SESSION_DATABASE_CONNECTION_TIMEOUT_MS=3000
SESSION_DATABASE_IDLE_TIMEOUT_MS=30000
SESSION_DATABASE_MAX_LIFETIME_SECONDS=300
READINESS_CHECK_TIMEOUT_MS=2500

DOCKER_HOST=unix:///var/run/docker.sock
CADDY_ADMIN_URL=http://127.0.0.1:12019
CADDY_ADMIN_TIMEOUT_MS=2500
CADDY_APP_UPSTREAM=host.docker.internal:3000
CADDY_PUBLIC_URL=http://localhost:18080
CADDY_ACCESS_LOG_PATH=infra/dev/caddy-logs/access.json
SESSION_PORT_START=20000
SESSION_PORT_END=20999
LOCAL_WORKER_ADDRESS=127.0.0.1
